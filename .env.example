# LINE
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Database (PostgreSQL)
DATABASE_URL=postgresql://botuser:botpass@localhost:5432/innovation_bot

# LLM (OpenRouter — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Any OpenRouter model id, e.g. google/gemini-2.5-flash, anthropic/claude-haiku-4.5
OPENROUTER_MODEL=google/gemini-2.5-flash

# Search
SERPER_API_KEY=

# App
PORT=3000
NODE_ENV=production
